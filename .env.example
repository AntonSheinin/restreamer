DEBUG=false
STREAMS_CONFIG=streams.toml
ACCESS_TOKEN=change-this-token

# Docker Compose host/container limits.
# Keep the bind host at 127.0.0.1 when only local Flussonic should consume this service.
RESTREAMER_BIND_HOST=127.0.0.1
RESTREAMER_PORT=8092
RESTREAMER_CPUS=6.0
RESTREAMER_MEMORY=4g
RESTREAMER_MEMORY_SWAP=4g
RESTREAMER_PIDS_LIMIT=512
RESTREAMER_STOP_GRACE_PERIOD=30s
RESTREAMER_NOFILE_SOFT=8192
RESTREAMER_NOFILE_HARD=8192

# 0 lets ffmpeg/libx264 choose automatically. Use 1-2 on shared Flussonic hosts.
FFMPEG_THREADS=2
